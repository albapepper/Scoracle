---
// Crystal Ball Sport Selector - Sports carousel inside the crystal ball with search
import { SPORTS, getSportDisplay } from '../lib/types';

interface Props {
  initialSport?: string;
}

const { initialSport = 'nba' } = Astro.props;

// Use centralized sport config
const sports = SPORTS.map(s => ({ id: s.idLower, display: s.display, logo: s.logo }));
const initialSportDisplay = getSportDisplay(initialSport);
---

<div class="crystal-ball-container">
  <!-- The logo with hands around crystal ball -->
  <div class="logo-wrapper">
    <img src="/logo.png" alt="Scoracle" class="crystal-logo" loading="eager" fetchpriority="high" />
    
    <!-- Sport selector overlay positioned inside the ball -->
    <div id="crystal-selector" class="crystal-selector" data-initial={initialSport}>
      <button 
        id="prev-sport" 
        class="nav-arrow nav-arrow-left" 
        aria-label="Previous sport"
      >
        <svg fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M15 19l-7-7 7-7"></path>
        </svg>
      </button>
      
      <div class="sport-display">
        {sports.map((sport) => (
          <div
            data-sport={sport.id}
            class={`sport-option ${initialSport === sport.id ? 'active' : ''}`}
          >
            <img src={sport.logo} alt={sport.display} class="sport-logo" loading="eager" />
          </div>
        ))}
      </div>
      
      <button 
        id="next-sport" 
        class="nav-arrow nav-arrow-right" 
        aria-label="Next sport"
      >
        <svg fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M9 5l7 7-7 7"></path>
        </svg>
      </button>
    </div>
  </div>
  
  <!-- Search bar below the carousel -->
  <div class="home-search-container" data-sport={initialSport}>
    <form id="home-search-form" class="home-search-form">
      <div class="home-search-input-wrapper">
        <input
          id="home-search-input"
          type="text"
          placeholder={`Search ${initialSportDisplay} players or teams...`}
          class="home-search-input"
          autocomplete="off"
        />
        <button
          type="submit"
          class="home-search-button"
          aria-label="Search"
        >
          <svg class="search-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path>
          </svg>
        </button>
      </div>
    </form>
    <div id="home-suggestions" class="home-suggestions-dropdown hidden"></div>
  </div>
</div>

<style>
  .crystal-ball-container {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.5rem;
  }

  .logo-wrapper {
    position: relative;
    display: flex;
    justify-content: center;
    align-items: center;
  }

  .crystal-logo {
    width: 693px;
    height: auto;
    margin-left: 15.75px;
  }

  /* Position the selector inside the crystal ball */
  .crystal-selector {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 2rem;
    padding: 0.5rem;
    margin-top: 1.5rem;
  }

  .nav-arrow {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 2rem;
    height: 2rem;
    background: transparent;
    border: 1px solid var(--border);
    border-radius: 50%;
    color: var(--text-secondary);
    cursor: pointer;
  }

  :global(.dark) .nav-arrow {
    border-color: var(--border-dark);
    color: var(--text-secondary-dark);
  }

  .nav-arrow svg {
    width: 1rem;
    height: 1rem;
  }

  .sport-display {
    position: relative;
    width: 120px;
    height: 120px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .sport-option {
    position: absolute;
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 0;
    transform: translateX(20px);
    transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .sport-logo {
    width: 157.5px;
    height: 157.5px;
    object-fit: contain;
  }

  .sport-option.active {
    opacity: 1;
    transform: translateX(0);
  }

  .sport-option.exit-up {
    opacity: 0;
    transform: translateX(-20px);
  }

  .sport-option.exit-down {
    opacity: 0;
    transform: translateX(20px);
  }

  .sport-option.enter-up {
    transform: translateX(-20px);
  }

  .sport-option.enter-down {
    transform: translateX(20px);
  }

  /* Home Search Bar Styles */
  .home-search-container {
    position: relative;
    width: 100%;
    max-width: 375px;
    margin: 0 auto;
  }

  .home-search-form {
    width: 100%;
  }

  .home-search-input-wrapper {
    display: flex;
    align-items: center;
    background-color: var(--bg-card);
    border-radius: 0.25rem;
    padding: 0.75rem 1rem;
    border: 1px solid var(--border);
    width: 100%;
  }

  :global(.dark) .home-search-input-wrapper {
    background-color: var(--bg-card-dark);
    border-color: var(--border-dark);
  }

  .home-search-input {
    flex: 1;
    background: transparent;
    border: none;
    outline: none;
    color: var(--text);
    font-size: 0.95rem;
    padding: 0;
    min-height: 24px;
  }

  :global(.dark) .home-search-input {
    color: var(--text-dark);
  }

  .home-search-input::placeholder {
    color: var(--text-tertiary);
  }

  :global(.dark) .home-search-input::placeholder {
    color: var(--text-tertiary-dark);
  }

  .home-search-button {
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 0.5rem;
    margin-left: 0.5rem;
    background: transparent;
    border: none;
    cursor: pointer;
    color: var(--text-tertiary);
    flex-shrink: 0;
  }

  :global(.dark) .home-search-button {
    color: var(--text-tertiary-dark);
  }

  .search-icon {
    width: 1.25rem;
    height: 1.25rem;
  }

  /* Suggestions Dropdown */
  .home-suggestions-dropdown {
    position: absolute;
    top: 100%;
    left: 0;
    right: 0;
    margin-top: 0.5rem;
    background-color: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: 0.25rem;
    max-height: 384px;
    overflow-y: auto;
    z-index: 10;
  }

  :global(.dark) .home-suggestions-dropdown {
    background-color: var(--bg-card-dark);
    border-color: var(--border-dark);
  }

  .home-suggestions-dropdown.hidden {
    display: none;
  }

  /* Suggestion Items */
  :global(.home-suggestion-item) {
    display: flex;
    align-items: center;
    justify-content: space-between;
    width: 100%;
    text-align: left;
    padding: 0.75rem 1rem;
    background: transparent;
    border: none;
    border-bottom: 1px solid var(--border);
    color: var(--text);
    cursor: pointer;
    font-size: 0.9375rem;
    gap: 0.75rem;
  }

  :global(.dark .home-suggestion-item) {
    border-bottom-color: var(--border-dark);
    color: var(--text-dark);
  }

  :global(.home-suggestion-item:last-child) {
    border-bottom: none;
  }

  :global(.home-suggestion-item:hover),
  :global(.home-suggestion-item.selected) {
    background-color: var(--bg);
  }

  :global(.dark .home-suggestion-item:hover),
  :global(.dark .home-suggestion-item.selected) {
    background-color: var(--bg-dark);
  }

  :global(.home-suggestion-info) {
    display: flex;
    flex-direction: column;
    flex: 1;
    min-width: 0;
  }

  :global(.home-suggestion-name) {
    font-weight: 500;
    color: var(--text);
  }

  :global(.dark .home-suggestion-name) {
    color: var(--text-dark);
  }

  :global(.home-suggestion-meta) {
    font-size: 0.8125rem;
    color: var(--text-secondary);
    margin-top: 0.125rem;
  }

  :global(.dark .home-suggestion-meta) {
    color: var(--text-secondary-dark);
  }

  :global(.home-suggestion-sport) {
    flex-shrink: 0;
    padding: 0.125rem 0.5rem;
    font-size: 0.6875rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.025em;
    border-radius: 0.25rem;
    background-color: var(--bg);
    color: var(--text-secondary);
    border: 1px solid var(--border);
  }

  :global(.dark .home-suggestion-sport) {
    background-color: var(--bg-dark);
    color: var(--text-secondary-dark);
    border-color: var(--border-dark);
  }

  :global(.home-no-results) {
    padding: 0.75rem;
    text-align: center;
    color: var(--text-secondary);
    font-size: 0.875rem;
  }

  :global(.dark .home-no-results) {
    color: var(--text-secondary-dark);
  }

  /* Scrollbar styling */
  .home-suggestions-dropdown::-webkit-scrollbar {
    width: 6px;
  }

  .home-suggestions-dropdown::-webkit-scrollbar-track {
    background: transparent;
  }

  .home-suggestions-dropdown::-webkit-scrollbar-thumb {
    background: var(--border);
    border-radius: 3px;
  }

  :global(.dark) .home-suggestions-dropdown::-webkit-scrollbar-thumb {
    background: var(--border-dark);
  }

  /* Responsive */
  @media (max-width: 480px) {
    .crystal-logo {
      width: 544.5px;
      margin-left: 12.375px;
    }

    .nav-arrow {
      width: 1.75rem;
      height: 1.75rem;
    }

    .nav-arrow svg {
      width: 0.875rem;
      height: 0.875rem;
    }

    .sport-display {
      width: 90px;
      height: 90px;
    }

    .sport-logo {
      width: 112.5px;
      height: 112.5px;
    }

    .home-search-container {
      max-width: 100%;
    }

    .home-search-input {
      font-size: 0.9rem;
    }
  }
</style>

<script>
  import { AutocompleteManager } from '../lib/utils/autocomplete';
  import { escapeHtml } from '../lib/utils/dom';
  import { getSportDisplay } from '../lib/types';

  const STORAGE_KEY = 'activeSport';

  class CrystalBallSelector {
    private container!: HTMLElement;
    private sportOptions!: NodeListOf<HTMLElement>;
    private prevBtn!: HTMLButtonElement;
    private nextBtn!: HTMLButtonElement;
    private sports!: string[];
    private currentIndex!: number;
    private isAnimating: boolean = false;

    constructor() {
      this.container = document.getElementById('crystal-selector')!;
      this.sportOptions = this.container.querySelectorAll('.sport-option');
      this.prevBtn = document.getElementById('prev-sport') as HTMLButtonElement;
      this.nextBtn = document.getElementById('next-sport') as HTMLButtonElement;

      // Build sports array from DOM
      this.sports = Array.from(this.sportOptions).map(el => el.dataset.sport!);
      
      // Load from localStorage or use initial
      const stored = localStorage.getItem(STORAGE_KEY);
      const initial = this.container.dataset.initial || 'nba';
      const savedSport = stored || initial;
      
      this.currentIndex = this.sports.indexOf(savedSport);
      if (this.currentIndex === -1) this.currentIndex = 0;

      this.init();
    }

    private init() {
      // Set initial active state
      this.updateDisplay();

      // Bind events
      this.prevBtn.addEventListener('click', () => this.navigate(-1));
      this.nextBtn.addEventListener('click', () => this.navigate(1));

      // Keyboard support
      this.container.addEventListener('keydown', (e) => {
        if (e.key === 'ArrowLeft') this.navigate(-1);
        if (e.key === 'ArrowRight') this.navigate(1);
      });

      // Dispatch initial event
      this.dispatchChange();
    }

    private navigate(direction: number) {
      if (this.isAnimating) return;
      
      this.isAnimating = true;
      const oldIndex = this.currentIndex;
      
      // Calculate new index with wrap-around
      this.currentIndex = (this.currentIndex + direction + this.sports.length) % this.sports.length;
      
      // Animate transition
      this.animateTransition(oldIndex, this.currentIndex, direction);
      
      // Save to localStorage
      localStorage.setItem(STORAGE_KEY, this.sports[this.currentIndex]);
      
      // Dispatch change event
      this.dispatchChange();
    }

    private animateTransition(oldIndex: number, newIndex: number, direction: number) {
      const oldEl = this.sportOptions[oldIndex];
      const newEl = this.sportOptions[newIndex];
      
      // Set exit animation
      oldEl.classList.remove('active');
      oldEl.classList.add(direction > 0 ? 'exit-up' : 'exit-down');
      
      // Set enter animation
      newEl.classList.add(direction > 0 ? 'enter-down' : 'enter-up');
      
      // Small delay then activate new element
      requestAnimationFrame(() => {
        requestAnimationFrame(() => {
          newEl.classList.remove('enter-up', 'enter-down');
          newEl.classList.add('active');
          
          // Clean up old element after transition
          setTimeout(() => {
            oldEl.classList.remove('exit-up', 'exit-down');
            this.isAnimating = false;
          }, 300);
        });
      });
    }

    private updateDisplay() {
      this.sportOptions.forEach((el, index) => {
        el.classList.toggle('active', index === this.currentIndex);
      });
    }

    private dispatchChange() {
      window.dispatchEvent(new CustomEvent('sportchange', { 
        detail: { sport: this.sports[this.currentIndex] } 
      }));
    }

    public getCurrentSport(): string {
      return this.sports[this.currentIndex];
    }
  }

  // Initialize carousel
  new CrystalBallSelector();

  // Initialize home page search
  const searchInput = document.getElementById('home-search-input') as HTMLInputElement;
  const searchSuggestions = document.getElementById('home-suggestions') as HTMLElement;
  const searchContainer = document.querySelector('.home-search-container') as HTMLElement;

  if (searchInput && searchSuggestions) {
    const stored = localStorage.getItem(STORAGE_KEY);
    const initialSport = stored || searchContainer?.dataset.sport || 'nba';

    const autocomplete = new AutocompleteManager({
      inputEl: searchInput,
      suggestionsEl: searchSuggestions,
      initialSport,
      itemClass: 'home-suggestion-item',
      onSelect: (entity) => {
        // Use the entity's sport field (which comes from the data store)
        // Fall back to current carousel sport if not available
        const sportParam = (entity.sport || autocomplete.getSport()).toUpperCase();
        window.location.href = `/news?sport=${sportParam}&type=${entity.type}&id=${entity.id}`;
      },
      renderItem: (entity, index) => {
        const sportDisplay = entity.sport ? getSportDisplay(entity.sport) : '';
        const metaText = entity.type === 'player' 
          ? (entity.team || 'Player') 
          : 'Team';
        
        return `
          <button
            type="button"
            data-index="${index}"
            class="home-suggestion-item"
            tabindex="-1"
          >
            <div class="home-suggestion-info">
              <div class="home-suggestion-name">${escapeHtml(entity.name)}</div>
              <div class="home-suggestion-meta">${escapeHtml(metaText)}</div>
            </div>
            ${sportDisplay ? `<span class="home-suggestion-sport">${escapeHtml(sportDisplay)}</span>` : ''}
          </button>
        `;
      },
    });

    // Listen for sport changes from carousel
    window.addEventListener('sportchange', ((e: CustomEvent) => {
      const newSport = e.detail.sport;
      autocomplete.setSport(newSport);
      // Update placeholder text
      searchInput.placeholder = `Search ${getSportDisplay(newSport)} players or teams...`;
    }) as EventListener);

    // Handle form submit (prevent default)
    document.getElementById('home-search-form')?.addEventListener('submit', (e) => {
      e.preventDefault();
    });
  }
</script>
