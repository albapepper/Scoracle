---
/**
 * Twitter Tab Component
 *
 * Displays tweets about an entity from trusted sports journalists.
 * Fetches: GET /api/v1/twitter/journalist-feed?q={entity_name}&sport={sport}&limit=10
 *
 * Features:
 * - Tweets with engagement metrics
 * - Author info
 * - Checks intel service availability
 * - Lazy loading when tab is activated
 */

const apiUrl = import.meta.env.PUBLIC_API_URL || 'http://localhost:8000/api/v1';
---

<div id="twitter-tab-content" data-api-url={apiUrl}>
  <div id="twitter-loading" class="loading-skeleton">
    <div class="skeleton-item"></div>
    <div class="skeleton-item"></div>
    <div class="skeleton-item"></div>
  </div>

  <div id="twitter-content" class="hidden">
    <div id="twitter-list" class="content-list"></div>
  </div>

  <div id="twitter-empty" class="empty-state hidden">
    No tweets found
  </div>

  <div id="twitter-unavailable" class="empty-state hidden">
    Twitter integration not configured
  </div>

  <div id="twitter-error" class="empty-state hidden">
    Unable to load tweets
  </div>
</div>

<style>
  .loading-skeleton {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .skeleton-item {
    height: 80px;
    border-radius: 4px;
    background-color: var(--border);
    animation: pulse 2s ease-in-out infinite;
  }

  :global(.dark) .skeleton-item {
    background-color: var(--border-dark);
  }

  @keyframes pulse {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.5; }
  }

  .content-list {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  #twitter-tab-content :global(.content-item) {
    padding-bottom: 1.5rem;
    border-bottom: 1px solid var(--border);
  }

  :global(.dark) #twitter-tab-content :global(.content-item) {
    border-bottom-color: var(--border-dark);
  }

  #twitter-tab-content :global(.content-item:last-child) {
    border-bottom: none;
    padding-bottom: 0;
  }

  #twitter-tab-content :global(.content-excerpt) {
    font-size: 0.9rem;
    color: var(--text);
    line-height: 1.5;
    margin: 0;
  }

  :global(.dark) #twitter-tab-content :global(.content-excerpt) {
    color: var(--text-dark);
  }

  #twitter-tab-content :global(.content-meta) {
    font-size: 0.8rem;
    color: var(--text-secondary);
    margin-top: 0.5rem;
  }

  :global(.dark) #twitter-tab-content :global(.content-meta) {
    color: var(--text-secondary-dark);
  }

  .empty-state {
    text-align: center;
    padding: 2rem;
    color: var(--text-secondary);
  }

  :global(.dark) .empty-state {
    color: var(--text-secondary-dark);
  }

  .hidden {
    display: none !important;
  }
</style>

<!-- JS logic is dynamically imported via content card's TabController (see lib/tabs/twitter-tab.ts) -->
