# Scoracle Astro Frontend Environment Variables
# Copy this to .env and adjust values as needed

# ─── Site URL ─────────────────────────────────────────────────────────────────
# Used for canonical URLs and SEO meta tags
SITE_URL=https://scoracle.vercel.app

# ─── Public URLs (available in client-side code) ─────────────────────────────
# These are used by the browser for client-side data fetching (tab switches,
# comparison mode, etc.)

# FastAPI backend (current primary backend)
PUBLIC_API_URL=https://scoracle-data-production.up.railway.app/api/v1

# PostgREST (future: direct DB access for stats/percentiles)
# PUBLIC_POSTGREST_URL=https://postgrest.scoracle.com

# Go backend (future: news, twitter endpoints)
# PUBLIC_GO_API_URL=https://go-api.scoracle.com

# ─── Private URLs (server-only, used during SSR) ─────────────────────────────
# These are used by the Astro SSR server to fetch data over Railway's private
# network. They never reach the browser. Set these in Railway's dashboard.

# FastAPI internal (same Railway project)
# FASTAPI_INTERNAL_URL=http://scoracle-data.railway.internal:8000/api/v1

# PostgREST internal (same Railway project)
# POSTGREST_INTERNAL_URL=http://postgrest.railway.internal:3000

# Go backend internal (same Railway project)
# GO_INTERNAL_URL=http://scoracle-go.railway.internal:8080

# ─── Node environment ────────────────────────────────────────────────────────
NODE_ENV=development
