---
/**
 * Team Profile Widget
 *
 * Displays team profile information from the backend.
 * Fetches: GET /api/v1/profile/team/{team_id}?sport={sport}
 *
 * Expected response structure (raw from backend):
 * {
 *   id, name, full_name, abbreviation, logo_url,
 *   city, country, venue_name, venue_capacity, founded,
 *   league: { id, name, country }
 * }
 */

import { serializeForHtml } from '../lib/utils/serialize';

interface Props {
  page?: 'news' | 'stats';
  showCompareButton?: boolean;
  /** SSR-provided profile data — skips client-side fetch when present */
  initialData?: unknown;
}

const { page = 'news', showCompareButton = false, initialData } = Astro.props;
const buttonText = page === 'news' ? 'View Stats' : 'View News';
const buttonDest = page === 'news' ? 'stats' : 'news';
const apiUrl = import.meta.env.PUBLIC_API_URL || 'http://localhost:8000/api/v1';

// Pre-compute display values from SSR data
const ssrProfile = initialData as any;
const ssrName = ssrProfile?.name || ssrProfile?.full_name || null;
const ssrLogo = ssrProfile?.logo_url || null;
const ssrSubtitle = ssrProfile?.venue_name || ssrProfile?.city || '';

const ssrDetails: Array<{ label: string; value: string }> = [];
if (ssrProfile) {
  if (ssrProfile.country) ssrDetails.push({ label: 'Country', value: ssrProfile.country });
  if (ssrProfile.founded) ssrDetails.push({ label: 'Founded', value: String(ssrProfile.founded) });
  if (ssrProfile.venue_capacity) ssrDetails.push({ label: 'Capacity', value: ssrProfile.venue_capacity.toLocaleString() });
  if (ssrProfile.league?.name) ssrDetails.push({ label: 'League', value: ssrProfile.league.name });
}

const urlSport = Astro.url.searchParams.get('sport');
const urlId = Astro.url.searchParams.get('id');
const navHref = urlSport && urlId ? `/${buttonDest}?sport=${urlSport}&type=team&id=${urlId}` : '#';
const hasSSRData = !!ssrProfile;
---

<div
  id="team-profile-widget"
  class="profile-widget card"
  data-api={apiUrl}
  data-dest={buttonDest}
  data-show-compare={showCompareButton ? 'true' : 'false'}
  data-has-ssr={hasSSRData ? 'true' : 'false'}
>
  {/* Embed SSR data for client-side hydration */}
  {initialData && (
    <script
      is:inline
      class="ssr-profile-data"
      type="application/json"
      set:html={serializeForHtml(initialData)}
    />
  )}

  <div class="pw-body">
    <!-- Loading (hidden when SSR data is present) -->
    <div id="team-pw-loading" class="pw-loading" style={hasSSRData ? 'display:none' : undefined}>
      <div class="skeleton-circle"></div>
      <div class="skeleton-line"></div>
      <div class="skeleton-line short"></div>
    </div>

    <!-- Content (visible when SSR data is present) -->
    <div id="team-pw-content" class="pw-content" style={hasSSRData ? 'display:flex' : undefined}>
      {ssrLogo ? (
        <img id="team-pw-logo" class="pw-logo" src={ssrLogo} alt={ssrName || ''} loading="lazy" />
      ) : (
        <img id="team-pw-logo" class="pw-logo" src="" alt="" loading="lazy" style="display: none;" />
      )}
      <h2 id="team-pw-name" class="pw-name">{ssrName || ''}</h2>
      <p id="team-pw-subtitle" class="pw-subtitle">{ssrSubtitle}</p>
      <div id="team-pw-details" class="pw-details">
        {ssrDetails.map(d => (
          <div class="pw-detail-item">
            <span class="pw-detail-label">{d.label}</span>
            <span class="pw-detail-value">{d.value}</span>
          </div>
        ))}
      </div>
    </div>

    <!-- Error -->
    <div id="team-pw-error" class="pw-error">
      <p>Unable to load team profile</p>
    </div>
  </div>

  <!-- Compare Button (+ icon) -->
  <button
    id="team-pw-compare-btn"
    class={`pw-compare-btn ${hasSSRData && showCompareButton ? '' : 'hidden'}`}
    type="button"
    title="Compare with another team"
    aria-label="Add comparison"
  >
    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
      <path d="M12 5v14M5 12h14" />
    </svg>
  </button>

  <!-- Navigation Button -->
  <a id="team-pw-button" href={navHref} class="pw-button">{buttonText}</a>
</div>

<style>
  .profile-widget {
    width: 100%;
    max-width: 600px;
    text-align: center;
    padding: 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    border-radius: 0.375rem;
    overflow: hidden;
    position: relative;
  }

  .pw-compare-btn {
    position: absolute;
    top: 0.75rem;
    right: 0.75rem;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 28px;
    height: 28px;
    padding: 0;
    background-color: var(--bg);
    border: 1px solid var(--border);
    border-radius: 50%;
    cursor: pointer;
    color: var(--text-tertiary);
    transition: color 0.15s, border-color 0.15s;
    z-index: 5;
  }

  .pw-compare-btn:hover {
    color: var(--text-secondary);
    border-color: var(--text-tertiary);
  }

  .pw-compare-btn.hidden {
    display: none;
  }

  :global(.dark) .pw-compare-btn {
    background-color: var(--bg-dark);
    border-color: var(--border-dark);
    color: var(--text-tertiary-dark);
  }

  :global(.dark) .pw-compare-btn:hover {
    color: var(--text-secondary-dark);
    border-color: var(--text-tertiary-dark);
  }

  .pw-body {
    padding: 1.5rem;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.75rem;
    width: 100%;
  }

  .pw-loading {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1rem;
  }

  .pw-content, .pw-error {
    display: none;
    flex-direction: column;
    align-items: center;
    gap: 0.75rem;
  }

  .skeleton-circle {
    width: 64px;
    height: 64px;
    border-radius: 50%;
    background: var(--border);
    animation: pulse 1.5s ease-in-out infinite;
  }

  .skeleton-line {
    height: 14px;
    width: 180px;
    border-radius: 4px;
    background: var(--border);
    animation: pulse 1.5s ease-in-out infinite;
  }

  .skeleton-line.short {
    width: 120px;
  }

  :global(.dark) .skeleton-circle,
  :global(.dark) .skeleton-line {
    background: var(--border-dark);
  }

  @keyframes pulse {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.5; }
  }

  .pw-logo {
    width: 80px;
    height: 80px;
    object-fit: contain;
    margin-bottom: 0.5rem;
  }

  .pw-name {
    font-size: 1.5rem;
    font-weight: 700;
    color: var(--text);
    margin: 0;
  }

  :global(.dark) .pw-name {
    color: var(--text-dark);
  }

  .pw-subtitle {
    font-size: 0.95rem;
    color: var(--text-secondary);
    margin: 0;
  }

  :global(.dark) .pw-subtitle {
    color: var(--text-secondary-dark);
  }

  .pw-details {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 0.75rem 1.5rem;
    margin-top: 0.5rem;
    font-size: 0.85rem;
    color: var(--text-secondary);
  }

  :global(.dark) .pw-details {
    color: var(--text-secondary-dark);
  }

  .profile-widget :global(.pw-detail-item) {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.125rem;
  }

  .profile-widget :global(.pw-detail-label) {
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    color: var(--text-tertiary);
  }

  :global(.dark) .profile-widget :global(.pw-detail-label) {
    color: var(--text-tertiary-dark);
  }

  .profile-widget :global(.pw-detail-value) {
    font-weight: 500;
    color: var(--text);
  }

  :global(.dark) .profile-widget :global(.pw-detail-value) {
    color: var(--text-dark);
  }

  .pw-error p {
    color: var(--text-secondary);
  }

  :global(.dark) .pw-error p {
    color: var(--text-secondary-dark);
  }

  .pw-button {
    display: block;
    padding: 0.875rem 1.25rem;
    background-color: var(--accent);
    color: var(--bg);
    text-decoration: none;
    font-weight: 500;
    font-size: 0.9rem;
    width: 100%;
    text-align: center;
  }

  :global(.dark) .pw-button {
    background-color: var(--accent-dark);
    color: var(--bg-dark);
  }

  /* Responsive - Mobile */
  @media (max-width: 480px) {
    .pw-body {
      padding: 1.25rem 1rem;
    }

    .pw-logo {
      width: 64px;
      height: 64px;
    }

    .pw-name {
      font-size: 1.25rem;
    }

    .pw-subtitle {
      font-size: 0.875rem;
    }

    .pw-details {
      gap: 0.5rem 1rem;
      font-size: 0.8rem;
    }

    .profile-widget :global(.pw-detail-label) {
      font-size: 0.65rem;
    }

    .pw-button {
      padding: 1rem;
      min-height: 48px;
    }
  }

  /* Extra small screens */
  @media (max-width: 320px) {
    .pw-body {
      padding: 1rem 0.75rem;
    }

    .pw-logo {
      width: 56px;
      height: 56px;
    }

    .pw-name {
      font-size: 1.1rem;
    }

    .pw-details {
      flex-direction: column;
      gap: 0.5rem;
    }
  }
</style>

<script>
  import { escapeHtml, parseEntityParams, showWidgetState } from '../lib/utils/dom';
  import { swrFetch, setPageData, CACHE_PRESETS } from '../lib/utils/api-fetcher';
  import { profileUrl } from '../lib/utils/data-sources';
  import { register } from '../lib/utils/component-bus';

  /**
   * Team profile data shape from backend
   */
  interface TeamProfileData {
    id: number;
    name?: string;
    full_name?: string;
    abbreviation?: string;
    logo_url?: string;
    city?: string;
    country?: string;
    venue_name?: string;
    venue_capacity?: number;
    founded?: number;
    league?: {
      id: number;
      name: string;
      country: string;
    };
  }

  class TeamProfileWidget {
    private widget: HTMLElement | null = null;
    private buttonDest = '';
    private showCompare = false;
    private sport: string | null = null;
    private id: string | null = null;

    private loadingEl: HTMLElement | null = null;
    private contentEl: HTMLElement | null = null;
    private errorEl: HTMLElement | null = null;
    private nameEl: HTMLElement | null = null;
    private subtitleEl: HTMLElement | null = null;
    private detailsEl: HTMLElement | null = null;
    private logoEl: HTMLImageElement | null = null;
    private buttonEl: HTMLAnchorElement | null = null;
    private compareBtnEl: HTMLButtonElement | null = null;

    private entityName: string = '';

    constructor() {
      const widget = document.getElementById('team-profile-widget');
      if (!widget) return;

      this.widget = widget;
      this.buttonDest = widget.dataset.dest || 'news';
      this.showCompare = widget.dataset.showCompare === 'true';

      const params = parseEntityParams();
      this.sport = params.sport;
      this.id = params.id;

      // Only proceed if this is a team entity
      if (params.type !== 'team') return;

      this.loadingEl = document.getElementById('team-pw-loading');
      this.contentEl = document.getElementById('team-pw-content');
      this.errorEl = document.getElementById('team-pw-error');
      this.nameEl = document.getElementById('team-pw-name');
      this.subtitleEl = document.getElementById('team-pw-subtitle');
      this.detailsEl = document.getElementById('team-pw-details');
      this.logoEl = document.getElementById('team-pw-logo') as HTMLImageElement;
      this.buttonEl = document.getElementById('team-pw-button') as HTMLAnchorElement;
      this.compareBtnEl = document.getElementById('team-pw-compare-btn') as HTMLButtonElement;

      // Check for SSR-provided data
      const hasSSR = widget.dataset.hasSsr === 'true';
      if (hasSSR) {
        this.hydrateFromSSR();
      }

      this.init(hasSSR);
      this.exposeAPI();
    }

    /**
     * Hydrate entity metadata from SSR-embedded data without re-fetching.
     */
    private hydrateFromSSR() {
      const ssrEl = this.widget?.querySelector('.ssr-profile-data');
      if (!ssrEl) return;

      try {
        const data = JSON.parse(ssrEl.textContent || '{}') as TeamProfileData;
        if (!data || !data.id) return;

        this.entityName = data.name || data.full_name || 'Unknown Team';

        setPageData('widget', {
          entity_id: data.id,
          entity_type: 'team',
          sport: this.sport,
          info: data,
        });
      } catch {
        // Parse failed — will fall through to client fetch
      }
    }

    private init(skipFetch = false) {
      if (this.sport && this.id && this.buttonEl) {
        this.buttonEl.href = `/${this.buttonDest}?sport=${this.sport}&type=team&id=${this.id}`;
      }

      // Setup compare button click handler
      if (this.compareBtnEl) {
        this.compareBtnEl.addEventListener('click', () => {
          this.onCompareClick();
        });
      }

      if (!this.sport || !this.id) {
        this.showError();
        return;
      }

      // Skip network fetch if SSR already provided the data
      if (skipFetch) return;

      this.fetchData();
    }

    private exposeAPI() {
      // Register widget API on component bus
      register('teamProfileWidget', {
        getSport: () => this.sport,
        getType: () => 'team' as const,
        getId: () => this.id,
        getName: () => this.entityName,
        hide: () => this.hide(),
        show: () => this.showWidget(),
      });
    }

    private onCompareClick() {
      window.dispatchEvent(new CustomEvent('comparison:add', {
        detail: {
          sport: this.sport,
          type: 'team',
          id: this.id,
          name: this.entityName,
        },
      }));
    }

    private async fetchData() {
      const { url, headers } = profileUrl(this.sport!, 'team', this.id!);

      try {
        const { data } = await swrFetch<TeamProfileData>(url, { ...CACHE_PRESETS.widget, headers });

        if (!data || !data.id) {
          this.showError();
          return;
        }

        // Share widget data with other components (raw data with entity metadata)
        setPageData('widget', {
          entity_id: data.id,
          entity_type: 'team',
          sport: this.sport,
          info: data,
        });

        this.renderData(data);
      } catch {
        this.showError();
      }
    }

    private renderData(data: TeamProfileData) {
      // Extract team-specific fields
      const name = data.name || data.full_name || 'Unknown Team';
      const logo = data.logo_url || '';
      const subtitle = data.venue_name || data.city || '';

      // Build details array for team
      const details: { label: string; value: string }[] = [];

      if (data.country) {
        details.push({ label: 'Country', value: data.country });
      }
      if (data.founded) {
        details.push({ label: 'Founded', value: String(data.founded) });
      }
      if (data.venue_capacity) {
        details.push({ label: 'Capacity', value: data.venue_capacity.toLocaleString() });
      }
      if (data.league?.name) {
        details.push({ label: 'League', value: data.league.name });
      }

      // Store entity name for API
      this.entityName = name;

      if (this.nameEl) this.nameEl.textContent = name;
      if (this.subtitleEl) this.subtitleEl.textContent = subtitle;

      // Render details
      if (this.detailsEl && details.length > 0) {
        this.detailsEl.innerHTML = details.map(d => `
          <div class="pw-detail-item">
            <span class="pw-detail-label">${escapeHtml(d.label)}</span>
            <span class="pw-detail-value">${escapeHtml(d.value)}</span>
          </div>
        `).join('');
      }

      if (this.logoEl && logo) {
        this.logoEl.src = logo;
        this.logoEl.alt = name;
        this.logoEl.style.display = 'block';
      }

      this.showContent();

      // Show compare button if enabled
      if (this.showCompare && this.compareBtnEl) {
        this.compareBtnEl.classList.remove('hidden');
      }
    }

    private showContent() { showWidgetState(this.loadingEl, this.contentEl, this.errorEl, 'content'); }
    private showError() { showWidgetState(this.loadingEl, this.contentEl, this.errorEl, 'error'); }

    private hide() {
      if (this.widget) this.widget.classList.add('hidden');
    }

    private showWidget() {
      if (this.widget) this.widget.classList.remove('hidden');
    }
  }

  new TeamProfileWidget();
</script>
