---
/**
 * Hamburger Menu Component
 *
 * Uses native <details>/<summary> for open/close toggle (zero JS for basic behavior).
 * Minimal JS added only for: click-outside-to-close, Escape-to-close, and localStorage.
 */
---

<details id="hamburger-menu" class="hamburger-menu-wrapper">
  <!-- Summary acts as the toggle button -->
  <summary class="header-btn hamburger-btn" aria-label="Toggle menu">
    <svg class="icon-large menu-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"></path>
    </svg>
    <svg class="icon-large close-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
    </svg>
  </summary>

  <!-- Dropdown Menu (shown/hidden by <details> open state) -->
  <div class="menu-dropdown">
    <div class="menu-content">
      <!-- Navigation Links -->
      <nav class="menu-nav">
        <a href="/" class="menu-link">
          <svg class="menu-link-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"></path>
          </svg>
          Home
        </a>
      </nav>

      <!-- Divider -->
      <hr class="menu-divider" />

      <!-- Language Selector -->
      <div class="menu-section">
        <p class="menu-section-title">Language</p>
        <div class="select-wrapper">
          <select id="language-select" class="menu-select">
            <option value="en">English</option>
            <option value="es">Español</option>
            <option value="fr">Français</option>
          </select>
        </div>
      </div>
    </div>
  </div>
</details>

<style scoped>
  /* Hide default <details> marker/triangle */
  .hamburger-menu-wrapper summary {
    list-style: none;
  }
  .hamburger-menu-wrapper summary::-webkit-details-marker {
    display: none;
  }

  .hamburger-menu-wrapper {
    position: relative;
  }

  .header-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 0.375rem;
    color: var(--text-secondary);
    background-color: transparent;
    outline: none;
    border: none;
    border-radius: 0.25rem;
    cursor: pointer;
  }

  :global(.dark) .header-btn {
    color: var(--text-secondary-dark);
  }

  .icon-large {
    width: 1.75rem;
    height: 1.75rem;
  }

  /* Icon switching via [open] attribute — no JS needed */
  .hamburger-menu-wrapper .close-icon {
    display: none;
  }
  .hamburger-menu-wrapper[open] .menu-icon {
    display: none;
  }
  .hamburger-menu-wrapper[open] .close-icon {
    display: block;
  }

  .menu-dropdown {
    position: fixed;
    top: 3.5rem;
    left: 0;
    width: 280px;
    max-height: calc(100vh - 3.5rem);
    overflow-y: auto;
    background-color: var(--bg);
    border-right: 1px solid var(--border);
    z-index: 40;
  }

  :global(.dark) .menu-dropdown {
    background-color: var(--bg-dark);
    border-right-color: var(--border-dark);
  }

  .menu-content {
    padding: 1.5rem 1rem;
  }

  .menu-content > * + * {
    margin-top: 1rem;
  }

  .menu-nav {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .menu-link {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 0.75rem 1rem;
    border-radius: 0.25rem;
    color: var(--text);
    text-decoration: none;
    font-weight: 500;
  }

  :global(.dark) .menu-link {
    color: var(--text-dark);
  }

  .menu-link-icon {
    width: 1.25rem;
    height: 1.25rem;
    flex-shrink: 0;
  }

  .menu-divider {
    border: none;
    border-top: 1px solid var(--border);
    margin: 1rem 0;
  }

  :global(.dark) .menu-divider {
    border-top-color: var(--border-dark);
  }

  .menu-section {
    padding: 0 0.5rem;
  }

  .menu-section-title {
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--text-tertiary);
    margin-bottom: 0.75rem;
  }

  :global(.dark) .menu-section-title {
    color: var(--text-tertiary-dark);
  }

  .select-wrapper {
    width: 100%;
  }

  .menu-select {
    width: 100%;
    padding: 0.625rem 0.75rem;
    border-radius: 0.25rem;
    border: 1px solid var(--border);
    background-color: var(--bg-card);
    color: var(--text);
    font-size: 0.875rem;
    outline: none;
    cursor: pointer;
  }

  :global(.dark) .menu-select {
    border-color: var(--border-dark);
    background-color: var(--bg-card-dark);
    color: var(--text-dark);
  }
</style>

<script>
  const LANG_STORAGE_KEY = 'preferred-language';
  const details = document.getElementById('hamburger-menu') as HTMLDetailsElement | null;

  if (details) {
    // Close on click outside
    document.addEventListener('click', (e) => {
      if (details.open && !details.contains(e.target as Node)) {
        details.open = false;
      }
    });

    // Close on Escape
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && details.open) {
        details.open = false;
      }
    });
  }

  // Language select persistence
  const langSelect = document.getElementById('language-select') as HTMLSelectElement | null;
  if (langSelect) {
    const saved = localStorage.getItem(LANG_STORAGE_KEY);
    if (saved) langSelect.value = saved;

    langSelect.addEventListener('change', () => {
      localStorage.setItem(LANG_STORAGE_KEY, langSelect.value);
    });
  }
</script>
