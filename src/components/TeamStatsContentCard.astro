---
/**
 * Team Stats Content Card
 *
 * Content card for the stats page when viewing a team entity.
 * Displays team statistics and related features in a tabbed interface.
 *
 * Tabs:
 * - Stats: Pizza chart + box score statistics + form display + home/away breakdown
 * - Strengths: Strengths & weaknesses based on percentiles
 * - Similarity: Similar teams based on embeddings
 */

import TeamStatsTab from './tabs/TeamStatsTab.astro';
import StrengthsWeaknessesTab from './tabs/StrengthsWeaknessesTab.astro';
import SimilarityTab from './tabs/SimilarityTab.astro';
import Momentum from './tabs/Momentum.astro';
import { serializeForHtml } from '../lib/utils/serialize';

interface Props {
  title?: string;
  /** SSR-provided stats data — allows client to skip network fetch */
  initialStats?: unknown;
}

const { title = 'Statistics', initialStats } = Astro.props;
---

<div class="team-stats-content-card card" data-entity-type="team">
  {/* Embed SSR stats data for client-side hydration */}
  {initialStats && (
    <script
      is:inline
      class="ssr-stats-data"
      type="application/json"
      set:html={serializeForHtml(initialStats)}
    />
  )}
  <!-- Tab Navigation -->
  <div class="tabs-nav">
    <button class="tab-btn active" data-tab="team-stats">Stats</button>
    <button class="tab-btn" data-tab="team-momentum">Momentum</button>
    <button class="tab-btn" data-tab="team-strengths">Strengths</button>
    <button class="tab-btn" data-tab="team-similarity">Similarity</button>
  </div>

  <!-- Tab Content -->
  <div class="tabs-content">
    <!-- Stats Tab -->
    <div id="team-stats-tab" class="tab-content active">
      <TeamStatsTab title={title} />
    </div>

    <!-- Momentum Tab -->
    <div id="team-momentum-tab" class="tab-content">
      <Momentum />
    </div>

    <!-- Strengths & Weaknesses Tab -->
    <div id="team-strengths-tab" class="tab-content">
      <StrengthsWeaknessesTab />
    </div>

    <!-- Similarity Tab -->
    <div id="team-similarity-tab" class="tab-content">
      <SimilarityTab />
    </div>
  </div>
</div>

<style>
  .team-stats-content-card {
    width: 100%;
    max-width: 600px;
    display: flex;
    flex-direction: column;
    border-radius: 0.375rem;
    overflow: hidden;
  }

  /* Tab Navigation */
  .tabs-nav {
    display: flex;
    justify-content: center;
    border-bottom: 1px solid var(--border);
    background-color: transparent;
  }

  :global(.dark) .tabs-nav {
    border-bottom-color: var(--border-dark);
  }

  .tab-btn {
    flex: 1;
    padding: 0.875rem 0.75rem;
    min-height: 48px;
    max-width: 140px;
    background: none;
    border: none;
    color: var(--text-secondary);
    font-weight: 500;
    font-size: 0.9rem;
    cursor: pointer;
    border-bottom: 2px solid transparent;
    transition: color 0.15s, border-color 0.15s;
    text-align: center;
  }

  :global(.dark) .tab-btn {
    color: var(--text-secondary-dark);
  }

  .tab-btn:hover {
    color: var(--text);
  }

  :global(.dark) .tab-btn:hover {
    color: var(--text-dark);
  }

  .tab-btn.active {
    color: var(--text);
    border-bottom-color: var(--text);
  }

  :global(.dark) .tab-btn.active {
    color: var(--text-dark);
    border-bottom-color: var(--text-dark);
  }

  .tabs-content {
    min-height: 300px;
  }

  .tab-content {
    display: none;
  }

  .tab-content.active {
    display: block;
  }

  /* Responsive - Mobile */
  @media (max-width: 480px) {
    .tabs-nav {
      gap: 0;
    }

    .tab-btn {
      padding: 0.75rem 0.25rem;
      font-size: 0.8rem;
    }
  }

  /* Extra small screens */
  @media (max-width: 320px) {
    .tab-btn {
      font-size: 0.75rem;
      padding: 0.75rem 0.125rem;
    }
  }
</style>

<script>
  import { initTabs } from '../lib/utils/tab-controller';
  import { get } from '../lib/utils/component-bus';

  const card = document.querySelector<HTMLElement>('.team-stats-content-card');
  if (card) {
    initTabs(card, {
      onTabChange: async (tabId) => {
        if (tabId === 'team-stats') get('teamStatsTab')?.load();
        if (tabId === 'team-momentum') (await import('../lib/tabs/momentum-tab')).init().load();
        if (tabId === 'team-strengths') (await import('../lib/tabs/strengths-weaknesses-tab')).init().load();
        if (tabId === 'team-similarity') (await import('../lib/tabs/similarity-tab')).init().load();
      },
      prefetch: {
        'team-similarity': async () => (await import('../lib/tabs/similarity-tab')).init().prefetch(),
      },
    });
  }
</script>
