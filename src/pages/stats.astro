---
/**
 * Stats Page — SSR
 *
 * Server-rendered: fetches profile + stats data over Railway's private network
 * during SSR, embeds it into the page, and hydrates client-side for interactivity.
 *
 * Pre-rendered data eliminates the loading skeleton for the initial view.
 * Lazy tabs (Momentum, Strengths, Similarity) still fetch client-side.
 */
export const prerender = false;

import Layout from '../layouts/Layout.astro';
import PlayerProfileWidget from '../components/PlayerProfileWidget.astro';
import TeamProfileWidget from '../components/TeamProfileWidget.astro';
import PlayerStatsContentCard from '../components/PlayerStatsContentCard.astro';
import TeamStatsContentCard from '../components/TeamStatsContentCard.astro';
import ComparisonSearchModal from '../components/ComparisonSearchModal.astro';
import ProfileWidgetComparison from '../components/ProfileWidgetComparison.astro';
import StatsComparisonContent from '../components/StatsComparisonContent.astro';
import { fetchStatsPageData } from '../lib/server/fetch';

// ─── SSR Data Fetching ───────────────────────────────────────────────────────

const sport = Astro.url.searchParams.get('sport');
const type = Astro.url.searchParams.get('type') || 'player';
const id = Astro.url.searchParams.get('id');

let ssrData: Record<string, unknown> | null = null;

if (sport && id) {
  const { profile, stats } = await fetchStatsPageData(sport, type, id);

  // Only embed if at least profile succeeded
  if (profile.data) {
    ssrData = {
      sport,
      type,
      id,
      profile: profile.data,
      stats: stats.data,        // may be null if stats fetch failed
      profileError: profile.error,
      statsError: stats.error,
    };
  }
}

// Build dynamic title from SSR data
const entityName = ssrData?.profile
  ? (ssrData.profile as any).full_name
    || (ssrData.profile as any).name
    || `${(ssrData.profile as any).first_name || ''} ${(ssrData.profile as any).last_name || ''}`.trim()
  : null;
const pageTitle = entityName ? `${entityName} Stats - Scoracle` : 'Stats - Scoracle';
---

<Layout
  title={pageTitle}
  description="View detailed statistics, comparisons, and predictions for sports players and teams"
>
  <!-- SSR Data Hydration -->
  {ssrData && (
    <script
      is:inline
      id="__SSR_DATA__"
      type="application/json"
      set:html={JSON.stringify(ssrData)}
    />
  )}

  <main class="stats-main">
    <!-- Single Entity View - Player -->
    <div id="player-entity-view" class="entity-view hidden" data-entity-type="player">
      <PlayerProfileWidget
        page="stats"
        showCompareButton={true}
        initialData={type === 'player' && ssrData?.profile ? ssrData.profile : undefined}
      />
      <PlayerStatsContentCard
        title="Statistics"
        initialStats={type === 'player' && ssrData?.stats ? ssrData.stats : undefined}
      />
    </div>

    <!-- Single Entity View - Team -->
    <div id="team-entity-view" class="entity-view hidden" data-entity-type="team">
      <TeamProfileWidget
        page="stats"
        showCompareButton={true}
        initialData={type === 'team' && ssrData?.profile ? ssrData.profile : undefined}
      />
      <TeamStatsContentCard
        title="Statistics"
        initialStats={type === 'team' && ssrData?.stats ? ssrData.stats : undefined}
      />
    </div>

    <!-- Comparison View (hidden by default) -->
    <div id="comparison-view" class="comparison-view hidden">
      <ProfileWidgetComparison />
      <StatsComparisonContent />
    </div>

    <!-- Comparison Search Modal -->
    <ComparisonSearchModal />
  </main>
</Layout>

<style>
  .stats-main {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.5rem;
    padding: 2rem 1rem 3rem;
    min-height: calc(100vh - 3.5rem);
    background-color: var(--bg);
  }

  :global(.dark) .stats-main {
    background-color: var(--bg-dark);
  }

  .entity-view {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.5rem;
    width: 100%;
  }

  .entity-view.hidden {
    display: none;
  }

  .comparison-view {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.5rem;
    width: 100%;
  }

  .comparison-view.hidden {
    display: none;
  }
</style>

<script>
  import type { AutocompleteEntity } from '../lib/utils/autocomplete';
  import { get, waitFor } from '../lib/utils/component-bus';
  import { setPageData } from '../lib/utils/api-fetcher';

  // ─── DOM refs ──────────────────────────────────────────────────────────────
  const playerView = document.getElementById('player-entity-view');
  const teamView = document.getElementById('team-entity-view');
  const comparisonView = document.getElementById('comparison-view');

  // ─── State ─────────────────────────────────────────────────────────────────
  const params = new URLSearchParams(window.location.search);
  const entityType = params.get('type') === 'team' ? 'team' : 'player';

  let primarySport = '';
  let primaryType = '';
  let primaryId = '';
  let primaryName = '';
  let primaryPositionGroup: string | undefined;
  let secondaryType = '';
  let secondaryId = '';
  let secondaryName = '';

  // ─── SSR hydration ─────────────────────────────────────────────────────────
  const ssrEl = document.getElementById('__SSR_DATA__');
  if (ssrEl) {
    try {
      const ssrData = JSON.parse(ssrEl.textContent || '{}');
      if (ssrData.profile) {
        setPageData('widget', {
          entity_id: ssrData.profile.id,
          entity_type: ssrData.type,
          sport: ssrData.sport,
          info: ssrData.profile,
        });
      }
    } catch {
      // SSR data parse failed — components will fetch client-side
    }
  }

  // ─── View helpers ──────────────────────────────────────────────────────────
  function showEntityView() {
    const isTeam = entityType === 'team';
    playerView?.classList.toggle('hidden', isTeam);
    teamView?.classList.toggle('hidden', !isTeam);
  }

  function enterComparisonMode() {
    playerView?.classList.add('hidden');
    teamView?.classList.add('hidden');
    comparisonView?.classList.remove('hidden');

    get('profileWidgetComparison')?.show(primarySport, primaryType, primaryId, secondaryType, secondaryId);
    get('statsComparisonContent')?.show(primarySport, primaryType, primaryId, secondaryType, secondaryId, primaryName, secondaryName);

    const url = new URL(window.location.href);
    url.searchParams.set('compareType', secondaryType);
    url.searchParams.set('compareId', secondaryId);
    window.history.replaceState({}, '', url.toString());
  }

  function exitComparisonMode() {
    comparisonView?.classList.add('hidden');
    showEntityView();
    get('profileWidgetComparison')?.hide();
    get('statsComparisonContent')?.hide();
    secondaryType = '';
    secondaryId = '';
    secondaryName = '';

    const url = new URL(window.location.href);
    url.searchParams.delete('compareType');
    url.searchParams.delete('compareId');
    window.history.replaceState({}, '', url.toString());
  }

  // ─── Init ──────────────────────────────────────────────────────────────────
  showEntityView();

  // Listen for comparison add request
  window.addEventListener('comparison:add', ((event: CustomEvent) => {
    const d = event.detail;
    primarySport = d.sport;
    primaryType = d.type;
    primaryId = d.id;
    primaryName = d.name;
    primaryPositionGroup = d.positionGroup;

    get('comparisonModal')?.open(
      primarySport, primaryType, primaryId,
      (entity: AutocompleteEntity) => {
        secondaryType = entity.type;
        secondaryId = entity.id;
        secondaryName = entity.name;
        enterComparisonMode();
      },
      primaryType === 'player' ? primaryPositionGroup : undefined,
    );
  }) as EventListener);

  window.addEventListener('comparison:removed', exitComparisonMode);

  // Restore comparison from URL if present
  async function checkURLForComparison() {
    const compareType = params.get('compareType');
    const compareId = params.get('compareId');
    if (!compareType || !compareId) return;

    try {
      const widgetName = entityType === 'team' ? 'teamProfileWidget' as const : 'playerProfileWidget' as const;
      const widget = await waitFor(widgetName, 5000);
      if (!widget.getSport()) return;

      primarySport = widget.getSport()!;
      primaryType = widget.getType();
      primaryId = widget.getId()!;
      primaryName = widget.getName() || 'Primary';
      secondaryType = compareType;
      secondaryId = compareId;
      secondaryName = 'Comparison';
      enterComparisonMode();
    } catch {
      // Widget didn't register in time
    }
  }

  document.addEventListener('DOMContentLoaded', () => checkURLForComparison());
</script>
